var bidengine  = {
    "version"  : 1.39 ,    // BID version
    "buildday" : 2026062602 ,  // BID 디렉토리가 Build 된 일자 "YYYYMMDD" + 일련번호 2자리
    "configs"  : [] ,      // Array of Page BID Config (초기 컨피그 설정)
    "objects"  : [] ,      // Array of Page BID Object (초기 오브젝트 설정)
    "sockets"  : {} ,      // JSON  of Socket.io Connect Socket
    "globals"  : {} ,      // JSON  of Global Data
    "libs"     : {} ,      // JSON  of BID Component Extend Function Library
    "sethashtag" : false   // true : URL hash Tag만 변하지 Action 은 일어나지 않는다. 이는 한번뿐이다.
} ;

var bidclass   = {} ;   // BID 컴퍼넌트 Class
var bidobject  = {} ;   // BID Object Instance of Class
var bidlibrary = {} ;   // BID Component Extend Function Library
var bidhtml    = {} ;   // JSON of BID Component Extend Html Tag
var bidscript  = [] ;   // BID 엔진으로 올린 Javascript File
var biderror   = {} ;   // BID Global Error
var bidobserver = new ResizeObserver ( aListEntries => {
    let sBidObject ;
    for (let oEntry of aListEntries) {
        // const {width, height} = oEntry.contentRect;
        sBidObject = oEntry.target.getAttribute('bid-object') ;
        if(window.bidobject[sBidObject]) {
            if(window.bidobject[sBidObject].fnBidObserver)
                window.bidobject[sBidObject].fnBidObserver( oEntry ) ;
        }
