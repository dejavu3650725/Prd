bidengine.callmodule = function(oTarget, sCmd, jParam, fcCallModule = () => {} ) {
    if ( typeof(oTarget) == "string" ) oTarget = $(oTarget) ;

    jParam.bid_object = jParam.bid_object?jParam.bid_object:bidengine.uniqid("bid-") ;
    oTarget.attr("bid_object", jParam.bid_object) ;
    oTarget.attr("bid-object", jParam.bid_object) ;

    // -- Setting Parameter : bid_module --
    if(!jParam.bid_module) {
        let eModule = {
            "err_code" : "error" ,
            "err_msg"  : "Not Found bid_module" ,
            "err_data" : jParam
        } ;
        fcCallModule(eModule) ;
        return false ;
    }

    switch(jParam.bid_module) {
        case "blank" :
            oTarget.empty() ;
            oTarget.data("param", null) ;
            oTarget.data("code",  null) ;
            fcCallModule(null) ;
            return ture ;
        break ;
    }

    let aCOM = jParam.bid_module.split(":") ;
    let jCurBid ;
    // -- Type : jQuery Plugin Function Style --
    switch(aCOM[0]) {
        case "class" :
            jParam.bid_cfgjsonurl = jParam.bid_cfgjsonurl?jParam.bid_cfgjsonurl:window.bid.cfgjsonurl ;
            jCurBid = {
                "cfgjsonurl" : jParam.bid_cfgjsonurl
            } ;
            bidengine.fpGetConfig( jCurBid, (eGetCfgJson , jBID ) => {
                if(eGetCfgJson) {
                    console.log(eGetCfgJson)  ;
                    fcCallModule(eGetCfgJson) ;
                    return
                }
                // Loading 이 안되었으면. Loading 한다.
                bidengine.frLoadingEmpty(oTarget) ;
                bidengine.IncludeClass( jParam.bid_module, jBID , ( eIncludeClass, jIncludeClass) => {
                    if( eIncludeClass ) {
                        oTarget.html( eIncludeClass.err_msg ) ;
                        return fcCallModule(eIncludeClass, null) ;
                    }
                    window.bidobject[jParam.bid_object] = new window.bidclass[jParam.bid_module]( oTarget, jParam, jBID ) ;
                    window.bidobject[jParam.bid_object].fnStartMethod(sCmd, null) ;
                    fcCallModule( null, window.bidobject[jParam.bid_object] ) ;
                } ) ;
            }) ;
        break ;
        default :
            jParam.bid_cfgjsonurl = jParam.bid_cfgjsonurl?jParam.bid_cfgjsonurl:window.bid.cfgjsonurl ;
            jCurBid = {
                "cfgjsonurl" : jParam.bid_cfgjsonurl
            } ;
            bidengine.fpGetConfig( jCurBid , function(eLoad, jBID ) {
                if(eLoad) {
                    console.log(eLoad) ;
                    return ;
                }
                jBID.url_front = ( jBID.url_front )?jBID.url_front:jBID.http + jBID.link_front ;
                jParam.bid_fronturl = jBID.url_front ;
                let sJsFile = jBID.url_front + "/" +  aCOM[1] + "/" + aCOM[0] + "/" +  aCOM[2] + "/" +  aCOM[3] + ".js" ;

                // Loading 이 안되었으면. Loading 한다.
                bidengine.loadScript( sJsFile, jQuery.fn[jParam.bid_module] , function(eLoadScript, jLoadState) {
                    if( eLoadScript ) {
                        console.log(eLoadScript) ;
                        return ;
                    }
                    // -- Parameter 를 이용하여, Object에서 사용하는 Code를 만든다. --
                    let bIsSet = true ;
                    let jTargetParam = oTarget.data("param") ;
                    if(!jTargetParam)
                        bIsSet = false ;
                    else {
                        bIsSet = ( jTargetParam.bid_module == jParam.bid_module )?true:false ;
                        if(bIsSet) bIsSet = oTarget.data("code").isset ;
                    }

                    if( !bIsSet ) {
                        let sModule_html = jBID.url_front + "/" +  aCOM[1] + "/" + aCOM[0] + "/" + aCOM[2] + "/" + aCOM[3] + ".html" ;

                        // Setting Default Code Information of jQuery Selector
                        var jCode   = {
                            "bid" : jBID , // 객체가 사용할 BID Configuration
                            "module_html"   : sModule_html  ,       // Html File 이 위치한 URL. 프로토콜 포함 "://"
                            "url_proc"      : jBID.url_cgi  ,
                            "object_key"    : bidengine.getuuid() , // 객체 Key 값
                            "isset"         : false                 // 객체가 아직 설치가 완료되지 않았음.
                        } ;
                        oTarget.data( "code", jCode ) ;
                    }

                    if(!oTarget[jParam.bid_module]) {
                        oTarget.html("Not Found Module [ " + jParam.bid_module + " ]") ;
                        fcCallModule( null, oTarget ) ;
                    }
                    else {
                        oTarget[jParam.bid_module](sCmd, jParam, jCode) ;
                        fcCallModule( null, oTarget ) ;
                    }
                } ) ;
            } ) ;
        break ;
    }
}

bidengine.fnCallObject = ( $Target, sCmd, jParam = {}, fcCallObject = () => {} ) => {
    if ( typeof($Target) == "string" ) $Target = $($Target) ;
    if ( $Target.length == 0 ) {
        window.biderror = {
            "err_code" : "error" ,
            "err_msg"  : "Not Found jQuery Document Selector" ,
            "_param"   : jParam
        } ;
        fcCallObject(window.biderror) ;
        return false ;
    }
    let sCurObject = $Target.attr("bid-object") ;
    console.log("Current BID Object : " + sCurObject ) ;
    // 전처리명령을 실행한다.

    if(!jParam.bid_object)
        jParam.bid_object = sCurObject?sCurObject:bidengine.uniqid("tmp-") ;

    if(jParam.bid_object != sCurObject) {
        bidengine.fnDeleteObject(sCurObject) ;
        $Target.attr("bid-object", jParam.bid_object) ;
        console.log("Change BID Object : " + jParam.bid_object ) ;
    }

    if( window.bidobject[jParam.bid_object] ) {
        console.log("Exist BID Object : " + jParam.bid_object ) ;
        window.bidobject[jParam.bid_object].fnStartMethod(sCmd, jParam ) ;
        fcCallObject( null, window.bidobject[jParam.bid_object] ) ;
        return true ;
    }

    // -- Setting Parameter : bid_module --
    if(!jParam.bid_module) {
        window.biderror = {
            "err_code" : "error" ,
            "err_msg"  : "Not Found bid_module" ,
            "err_data" : jParam
        } ;
        fcCallObject(window.biderror) ;
        return false ;
    }

    jParam.bid_cfgjsonurl = jParam.bid_cfgjsonurl?jParam.bid_cfgjsonurl:window.bid.cfgjsonurl ;
    let jCurBid = {
        "cfgjsonurl" : jParam.bid_cfgjsonurl
    } ;
    bidengine.fpGetConfig( jCurBid, (eGetCfgJson , jBID ) => {
        if(eGetCfgJson)
            return fcCallObject(eGetCfgJson) ;
        bidengine.IncludeClass( jParam.bid_module, jBID , ( eIncludeClass, jIncludeClass ) => {
            console.log("Loading Module Class : " + jParam.bid_module ) ;
            if( eIncludeClass )
                return fcCallObject(eIncludeClass, null) ;
            // console.log( jIncludeClass ) ;
            window.bidobject[jParam.bid_object] = new window.bidclass[jParam.bid_module]( $Target, jParam, jBID ) ;
            if(sCmd)
                window.bidobject[jParam.bid_object].fnStartMethod(sCmd, jParam ) ;
            fcCallObject( null, window.bidobject[jParam.bid_object] ) ;
        } ) ;
    }) ;
    return true ;
}

bidengine.fnDeleteObject = ( sBidObject, bRemoveSelector = false ) => {
    let jDelTag = { "bidobj" : false , "biddoc" : false } ;
    if(window.bidobject[sBidObject]) {
        console.log("Delete BID Object : " + sBidObject ) ;
        delete window.bidobject[sBidObject] ;
        jDelTag.bidobj = true ;
    }
    let $Target = $("[bid-object='"+sBidObject+"']") ;
    if($Target.length > 0) {
        $Target.empty() ;
        $Target.removeAttr("bid-object") ;
        if(bRemoveSelector)
            $Target.remove() ;
        jDelTag.biddoc = true ;
    }
    return jDelTag ;
}

bidengine.fnCleanObject = () => {
    let $Target ;
    let jCleanTag = {
        "deleteobjects" : []
    } ;
    Object.keys(window.bidobject).forEach(sBidObject => {
        $Target = $("[bid-object='"+sBidObject+"']") ;
        if($Target.length == 0) {
            delete window.bidobject[sBidObject] ;
            jCleanTag.deleteobjects.push(sBidObject) ;
        }
    });
    return jCleanTag ;
} ;

bidengine.fnMakeupConfig = (jCurBid) => {
    // Setting 6 Link - 더 이상 사용하지 않을 예정
    jCurBid.link_app      = jCurBid.link_app?jCurBid.link_app:"/bid_app" ;
    jCurBid.link_config   = jCurBid.link_config?jCurBid.link_config:"/bid_config" ;
    jCurBid.link_front    = jCurBid.link_front?jCurBid.link_front:"/bid_front" ;
    jCurBid.link_frontext = jCurBid.link_frontext?jCurBid.link_frontext:"/bid_frontext" ;
    jCurBid.link_file     = jCurBid.link_file?jCurBid.link_file:"/bid_file"    ;
    jCurBid.link_proc     = jCurBid.link_proc?jCurBid.link_proc:"/bid_config/cgi." + jCurBid.cgi_ext ;

    /* URL 설정 --
        *. "url_init"      : 이미 설정
        *. "url_socket"    : 이미 설정
        1. "url_config"    : null ,
        2. "url_app"       : null ,
        3. "url_front"     : null ,
        4. "url_frontext"  : null ,
        5. "url_file"      : null ,
        6. "url_proc"      : 이 부분은 변경요망, 앞으로 url_cgi 로 변경처리
        7. "url_cgi"       : null ,
    */
    jCurBid.url_config    = jCurBid.url_config?jCurBid.url_config:jCurBid.url_init + "/bid_config/" ;
    jCurBid.url_app       = jCurBid.url_app?jCurBid.url_app:jCurBid.url_init + "/bid_app/" ;
    jCurBid.url_front     = jCurBid.url_front?jCurBid.url_front:jCurBid.url_init + "/bid_front/" ;
    jCurBid.url_frontext  = jCurBid.url_frontext?jCurBid.url_frontext:jCurBid.url_init + "/bid_frontext/" ;
    jCurBid.url_file      = jCurBid.url_file?jCurBid.url_file:jCurBid.url_init + "/bid_file/" ;
    jCurBid.url_proc      = jCurBid.url_proc?jCurBid.url_proc:jCurBid.url_init + "/bid_config/cgi." + jCurBid.cgi_ext ;
    jCurBid.url_cgi       = jCurBid.url_cgi?jCurBid.url_cgi:jCurBid.url_init + "/bid_config/cgi." + jCurBid.cgi_ext ;

    // Set Data
    jCurBid.pkg_param = jCurBid.pkg_param?jCurBid.pkg_param:{} ;
    jCurBid.ext_param = jCurBid.ext_param?jCurBid.ext_param:{} ;
    jCurBid.set_pkg   = jCurBid.set_pkg?jCurBid.set_pkg:{}   ;
    jCurBid.set_ext   = jCurBid.set_ext?jCurBid.set_ext:{}   ;
    jCurBid.set_user  = jCurBid.set_user?jCurBid.set_user:{} ;
    window.bidengine.configs.push ( jCurBid ) ;
    return jCurBid ;
} ;

bidengine.fpGetConfig = (jCurBid, fcGetCfgjson) => {
    // -- Check Loading BID Config --
    let aTconfig = window.bidengine.configs.filter((jBID) => { return jBID.cfgjsonurl === jCurBid.cfgjsonurl ; } ) ;
    if( aTconfig.length > 0 ) return fcGetCfgjson( null, aTconfig[ aTconfig.length - 1 ] ) ;

    if( jCurBid.site_key ) {
        jCurBid = bidengine.fnMakeupConfig(jCurBid) ;
        return fcGetCfgjson( null, jCurBid ) ;
    }

    // -- /Check Loading BID Config --
    $.ajax ( {
        "type"      : "GET"  ,
        "url"       : jCurBid.cfgjsonurl  ,
        "cache"     : false ,
        "async"     : true  ,
        "crossDomain" : true ,
        "dataType"  : "json" ,
        "success"   : (jReturn) => {
            let jCfgBID = jQuery.extend( true, {}, jReturn ) ;
            if(jCfgBID.site_id == "error") {
                let eGetCfgJson = {
                    "err_code" : "@bid.base" ,
                    "err_msg"  : "Error Loading Config Json File" ,
                    "response" : jReturn
                } ;
                return fcGetCfgjson( eGetCfgJson, null ) ;
            }
            jCfgBID.cfgjsonurl  = jCurBid.cfgjsonurl ;
            jCfgBID = bidengine.fnMakeupConfig(jCfgBID) ;
            return fcGetCfgjson( null, jCfgBID ) ;
        } ,
        "error" : (jXHR, sAjaxStatus, eThrown) => {
            let eAjax = {
                "err_code" : "@bid.base" ,
                "err_msg"  : bidengine.jquery_xhrerror(jXHR, sAjaxStatus, eThrown, true) ,
                "err_data" : null
            }
            return fcGetCfgjson( eAjax, null) ;
        }
    }) ;
}

/* -- bidengine Load Resource Library : 4 개 --
1. bidengine.loadScript ( sUrl, jObject, fnCallback )  : Load Javascript
    sUrl : Javascript File URL
    jObject : 필요한 Javascript Object Loading 판단 유무
    fnCallback ( jError, { "loading" : true/false } )
2. bidengine.MultiloadScript ( aLoadInfo, fnCallback ) : 다중 Load Javascript
    aLoadInfo : Javascrit Url & jObject Information Array
    fnCallback( jError )
3. bidengine.loadCss (sUrl) : Load CSS Style File
    sUrl : CSS Style File Url
4. bidengine.loadHtml ($This, fnCallback) : 컴퍼넌트 지정 Html Skin Loading
    $This : 컴퍼넌트 지정 jQuery Selector
    fnCallback( jError ) ;
-- */

bidengine.loadScript = (sUrl, jObject, fcLoadScript = () => {} ) => {
    if ( typeof(jObject) != "string" ) {
        try {
            jObject = eval(jObject) ;
        }
        catch( jEobject ) {
            console.log( jEobject ) ;
            fcLoadScript( {
                "err_code" : "bidengine.loadScript" ,
                "err_msg"  : jEobject.toString() ,
                "err_data" : null
            } , { "loading" : false } ) ;
            return ;
        }
    }

    if ( jObject != undefined ) return fcLoadScript(null, { "loading" : false } ) ;  // Return of Exist
    if ( window.bidscript.indexOf(sUrl) >= 0 ) return fcLoadScript(null, { "loading" : false } ) ;  // Return of Exist

    jQuery.ajax ( {
        type    : "GET"  ,
        url     : sUrl   ,
        async   : true   ,
        data    : null   ,
        crossDomain : true ,
        dataType: "script" ,
        success :  () => {
            window.bidscript.push(sUrl) ;
            fcLoadScript( null, { "loading" : true } ) ;
        } ,
        error : (jXHR, sAjaxStatus, eThrown) => {
            let eResult = {
                "err_code"  : "bidengine.loadScript" ,
                "err_msg"   : bidengine.jquery_xhrerror(jXHR, sAjaxStatus, eThrown, false) ,
                "err_data"  : ""
            } ;
            return fcLoadScript( eResult ) ;
        }
    } ) ;
}

bidengine.MultiloadScript = ( aLoadInfo, fcMultiloadScript ) => {
