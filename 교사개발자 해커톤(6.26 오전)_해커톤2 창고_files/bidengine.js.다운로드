}) ;
/* -- 1. bidengine Core Library : 5 개 --
1.1. bidengine.setengine ( fcSetEngine )  : Bid Configuration 을 이용한 Engine 설정
1.2. bidengine.startengine (fcStartEngine) : Bid Engine 시작
1.3. bidengine.initobject () : bidengine.objects[] Array 를 이용한 Hash Tag 설정
1.4. bidengine.callmodule (oTarget, sCmd, jParam, fnCallback) : 실제 Object Module 실행 -> fnCallObject 로 대처
    oTarget : jQuery Selector
    sCmd : Module Method
    jParam : Module Parameter
    fnCallback( jError, oTarget )
    -- Default Parameter : 5 --
    1) bid_object     : Option
    2) bid_method     :
    3) bid_module     : Module Code
    4) bid_cfgjsonurl : 없으면 window.bid.cfgjsonurl 로 치환 (Page 와 같은 Configuration)
1.5. bidengine.fpGetConfig ( sUrl, fnCallback ) : Call BID Configuration
    sUrl : Config JSON File URL
    fnCallback( jError , jCfgBID )
-- */
bidengine.setengine = ( fcSetEngine = () => {} ) => {
    // -- Setting Trigger Module Object HashChange --
    bidengine.fpGetConfig( window.bid , ( eGetConfig, jCfgBID ) => {
        if(eGetConfig) return fcSetEngine(eGetConfig) ;
        window.bid = $.extend( true, window.bid, jCfgBID )  ;
        /*--
            location.origin 은 Page와 Bid Configuration 이 일치해야 할 경우 설정한다.
        --*/
        if( window.bid.origin_front ) {
            if ( document.location.origin != window.bid.origin_front ) {
                let eOrigin = {
                    "err_code" : "@bid.base" ,
                    "err_msg"  : "'window.bid.origin_front' Origin Mismatch '" + window.bid.origin_front + "'" ,
                    "err_data" : null
                }
                fcSetEngine(eOrigin) ;
            }
        }
        window.bid.protocol  = document.location.protocol   ;
        jQuery.ajaxSetup( { "cache" : !window.bid.debug } ) ;

        // -- Setting Request Get Data & Hash Data --
        var aQueries = document.location.search.replace(/^\?/, '').split('&') ;
        window.bid.get = {} ;
        for( var i = 0; i < aQueries.length; i++ ) {
            if(!aQueries[i]) continue ;
            aSplit = aQueries[i].split('=') ;
            window.bid.get[aSplit[0]] = decodeURIComponent(aSplit[1]) ;
        }

        window.bid.hash = bidengine.getlocationhash() ;
        if (!window.bid.ajaxtimeout || (window.bid.ajaxtimeout <= 0) ) window.bid.ajaxtimeout = 60000 ;
        jQuery.ajaxSetup( { "timeout" : window.bid.ajaxtimeout } ) ;

        $(window).off("hashchange").on('hashchange', (jEvent, uDumy) => {
            if( window.bidengine.sethashtag ) {
                window.bidengine.sethashtag = false ;
                return ;
            }
            let iCntAction = window.bidengine.objects.length ;
            // console.log(window.bidengine.objects) ;
            let jCurAction, sSelector, sHash ;
            for ( let i = 0 ; i < iCntAction ; i ++ ) {
                jCurAction = window.bidengine.objects[i] ;
                sSelector  = "[data-bid-object='" + jCurAction.bid_object + "']" ;
                if($(sSelector).length == 0) {
                	sSelector  = "[bid_object='" + jCurAction.bid_object + "']" ;
                }
                sHash = window.bidengine.getlocationhash(jCurAction.bid_object) ;
                if(sHash) {
                    try {
                        var jParamCur = JSON.parse(sHash) ;
                        // console.log( "Call Hash : " + jParamCur.bid_method ) ;
                        window.bidengine.callmodule( sSelector, jParamCur.bid_method, jParamCur ) ;
                    }
                    catch(eBlock) {
                        // console.log("-- Hash Tag Error --") ;
                        console.log(eBlock) ;
                        window.bidengine.callmodule( sSelector , jCurAction.bid_method, jCurAction ) ;
                        return ;
                    }
                }
                else {
                    window.bidengine.callmodule( sSelector , jCurAction.bid_method, jCurAction ) ;
                }
            }
        } ) ;
        fcSetEngine(null) ;
    } ) ;
} ;

bidengine.startengine = (fcStartEngine = () => {} ) => {
    bidengine.fpGetConfig( window.bid, (eGetCfgJson, jBID ) => {
        if(eGetCfgJson) {
            console.log(eGetCfgJson) ;
            return fcStartEngine(eGetCfgJson, null) ;
        }
        window.bidengine.initobject() ;
        $(window).trigger("hashchange") ;
        fcStartEngine(null, jBID) ;
    }) ;
}

bidengine.initobject = () => {
    let iCntAction = window.bidengine.objects.length ;
    bidengine.clog( 2, " Setting Trigger Module Object HashChange : " + iCntAction ) ;
    let jCurAction, sSelector ;
    for ( i = 0 ; i < iCntAction ; i ++ ) {
        jCurAction = window.bidengine.objects[i] ;
        sSelector  = "[data-bid-object='" + jCurAction.bid_object + "']" ;
        if($(sSelector).length == 0) {
        	sSelector  = "[bid-object='" + jCurAction.bid_object + "']" ;
        }
        if($(sSelector).length == 0) continue ;
        $(sSelector).off("startmethod").on("startmethod", ( eStartMethod, jStartMethod) => {
            if(!jStartMethod.bid_object) return ;
            let sValue = JSON.stringify(jStartMethod) ;
            window.bidengine.sethashtag = true ;
            window.bidengine.setlocationhash(jStartMethod.bid_object, sValue) ;
        }) ;
    }
} ;

bidengine.IncludeClass = function( sBidModule, jBID, fcIncludeClass) {
    let aCOM  = sBidModule.split(":") ;
    jBID  = jBID?jBID:window.bid ;
    let sJsFile = jBID.url_front + "/" +  aCOM[1] + "/" + aCOM[0] + "/" +  aCOM[2] + "/" +  aCOM[3] + ".js" ;
    if(bidengine.buildday)
        sJsFile += "?_bid_buildday=" + bidengine.buildday ;

    bidengine.loadScript( sJsFile, window.bidclass[sBidModule], (eLoadScript, jLoadState) => {
        if(eLoadScript)
            return fcIncludeClass(eLoadScript, jLoadState) ;

        if(window.bidclass[sBidModule].fpInitClass) {
            window.bidclass[sBidModule].fpInitClass( jBID, (eInitClass, jInitClass) => {
                return fcIncludeClass(eInitClass, jInitClass) ;
            }) ;
        }
        else {
            return fcIncludeClass(eLoadScript, jLoadState) ;
        }
    }) ;
}

bidengine.fnLoadClassCss = function( sBidModule, jBID, fcLoadClassCss = () => {} ) {
    let aCOM  = sBidModule.split(":") ;
    jBID  = jBID?jBID:window.bid ;
    let sCssFile = jBID.url_front + "/" +  aCOM[1] + "/" + aCOM[0] + "/" +  aCOM[2] + "/" +  aCOM[3] + ".css" ;
    if(bidengine.buildday)
        sCssFile += "?_bid_buildday=" + bidengine.buildday ;
    bidengine.loadCss(sCssFile) ;
    return fcLoadClassCss ;
}

