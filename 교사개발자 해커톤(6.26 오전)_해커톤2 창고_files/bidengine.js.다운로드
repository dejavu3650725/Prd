                + "<br/>jXHR.status : " + jXHR.status
                + "<br/>jXHR.statusText : " + jXHR.statusText ;
    }
    else {
        sError  = "sAjaxStatus : " + sAjaxStatus
                + "\n" + "eThrown : " + eThrown
                + "\n" + "jXHR.status : " + jXHR.status
                + "\n" + "jXHR.statusText : " + jXHR.statusText ;
    }
    return sError ;
}

bidengine.getuuid = (sGsep) => {
    var sSep = sGsep?sGsep:"" ;
    var S4 = function () { return  Math.floor(Math.random() * 0x10000).toString(16) ; } ;
    return ( S4() + S4() + sSep + S4() + sSep + S4() + sSep + S4() + sSep + S4() + S4() + S4() ) ;
} ;

