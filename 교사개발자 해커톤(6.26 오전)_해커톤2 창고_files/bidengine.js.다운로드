/*----- Bid Certification Extend Library : 6 개 ----
1. bidengine.makeheader ( jBID, sProcKey, sProcValue) : Http Header Make Function
    jBID : BID Configuration
    sProcKey   : Process Key
    sProcValue : Process Value
    * Return : JSON { "x-bid-token" : sHeaderValue }
2. bidengine.inittoken ( jBID ) : Cert Token 초기화
    jBID : BID Configuration
3. bidengine.getstatevalue ( jBID , sState_key , fnCallback ) : Key + Value 값 설정
    jBID : BID Configuration
    sState_key : 상태 key 값
    fnCallback : Callback Function ( jError, StateKeyInfo )
-------*/
bidengine.makeheadervalue = ( jBID, sProcKey, sProcValue ) => {
    // -- Site : dev_key setting --
    let sDev_key = localStorage.getItem("bid.dev_key:" + jBID.site_id)  ;
    let iKeep    = localStorage.getItem("bid.keep:" + jBID.site_id)     ;
    if(!sDev_key) {
        sDev_key = bidengine.uniqid() ;
        localStorage.setItem("bid.dev_key:" + jBID.site_id, sDev_key)   ;
    }
    if(!iKeep) {
        iKeep = 0 ;
        localStorage.setItem("bid.keep:" + jBID.site_id, iKeep )  ;
    }
    let sToken_type = (jBID.token_type)?jBID.token_type:"default" ;
    let sToken, sHeaderValue ;

    switch(sToken_type) {
        case "api" :
        break ;
        default : // sHeader Value : Token Type / Device Key / Process Key / Process Value / Token
            sToken = ( iKeep > 0 )?localStorage.getItem("bid.token:" + jBID.site_id):sessionStorage.getItem("bid.token:" + jBID.site_id) ;
            sHeaderValue = sToken_type + "|" + sDev_key + "|" + sProcKey + "|" + sProcValue ;
            if(sToken)
                sHeaderValue += "|" + sToken ;  // JWT
        break ;
    }
    return sHeaderValue ;
}

bidengine.makeheader  = ( jBID, sProcKey, sProcValue) => {
    var sHeaderValue = bidengine.makeheadervalue( jBID, sProcKey, sProcValue ) ;
    return { "x-bid-token" : sHeaderValue } ;
} ;

bidengine.inittoken = function( jBID ) {
    localStorage.removeItem("bid.token:" + jBID.site_id) ;
    sessionStorage.removeItem("bid.token:" + jBID.site_id) ;
    localStorage.setItem("bid.keep:" + jBID.site_id, 1 ) ;
    return ;
} ;

