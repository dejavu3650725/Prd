bidengine.text2html = function( sSrcText, jOptConvert ) {
    // sSrcText = sSrcText,"") ;
    let hRtnHtml = sSrcText ;
    // -- nl2br --
    hRtnHtml = hRtnHtml.replace(/(?:\r\n|\r|\n)/g, '<br/>');

    // -- " " -> &nbsp;
    hRtnHtml = hRtnHtml.replace(/ /gi , "&nbsp;" ) ;
    hRtnHtml = hRtnHtml.replace(/\t/gi, "&nbsp;&nbsp;&nbsp;&nbsp;" ) ;

    // -- "<", ">" -> &lt; , &gt;
    // hRtnHtml = hRtnHtml.replace(/</gi, "&lt;" ) ;
    // hRtnHtml = hRtnHtml.replace(/>/gi, "&gt;" ) ;

    return hRtnHtml ;
} ;

bidengine.fnGetPlatform = () => {
    let sPlatForm = window.navigator.platform?window.navigator.platform:window.navigator.userAgentData.platform ;
    if (sPlatForm.toLowerCase().includes('win')) {
        return "win" ;
    } else if (sPlatForm.toLowerCase().includes('mac')) {
        return "mac" ;
    } else if (sPlatForm.toLowerCase().includes('linux')) {
        return "linux" ;
    } else if (sPlatForm.toLowerCase().includes('iphone') || sPlatForm.toLowerCase().includes('ipad') || sPlatForm.toLowerCase().includes('ipod')) {
        return "ios" ;
    } else if (sPlatForm.toLowerCase().includes('android')) {
        return "android" ;
    } else {
        return null ;
    }
} ;

bidengine.fgTextColorByBackgroundColor = (sHexColor) => {
    const c = sHexColor.substring(1) // 색상 앞의 # 제거
    const rgb = parseInt(c, 16)      // rrggbb를 10진수로 변환
    const r = (rgb >> 16) & 0xff     // red 추출
    const g = (rgb >>  8) & 0xff     // green 추출
    const b = (rgb >>  0) & 0xff     // blue 추출
    const luma = 0.2126 * r + 0.7152 * g + 0.0722 * b // per ITU-R BT.709
    // 색상 선택
    return luma < 127.5 ? "white" : "black" // 글자색이
}

bidengine.frSetOverlayTarget = ( $Target, sActCode ) => {
    /*  Setting CSS
        1. overflow : hidden
        2. position : absolue, relative, fix
        3. padding-left, padding-bottom : ScrollBar 때문..
    */
    let $CurTarget   = $Target?$Target:$("body") ;
    let sCurOverflow ;
    switch(sActCode) {
        case "showoverlay" :
            sCurOverflow = $CurTarget[0].style.overflow ;
            $CurTarget.data("bid-prev-overflow", sCurOverflow) ;
            $CurTarget[0].style.overflow = "hidden" ;
        break ;
        case "hideoverlay" :
            sResOverflow = $CurTarget.data('bid-prev-overflow') ; //  [핵심] 저장해두었던 이전 값을 가져옴 (없다면 기본값 auto)
            $CurTarget[0].style.overflow = sResOverflow ;
        break ;
        default :

        break ;
    }
    return $CurTarget ;
} ;
/*-- Cookie Library : 4 개 --
1. bidengine.fnGetCookie() : Cookie 를 가지고 온다.
2. bidengine.fnSetCookie() : Cookie 를 설정한다.
3. bidengine.fnDeleteCookie() : Cookie 를 삭제한다.
4. bidengine.fnDeleteAllCookie() : 전체 Cookie 를 삭제한다.
--*/
bidengine.fnGetCookie = (name) => {
    let matches = document.cookie.match(new RegExp(
      "(?:^|; )" + name.replace(/([\.$?*|{}\(\)\[\]\\\/\+^])/g, '\\$1') + "=([^;]*)"
    ));
    return matches ? decodeURIComponent(matches[1]) : undefined;
} ;

bidengine.fnSetCookie = ( name, value, options = {}) => {
    options.path = options.path?options.path:"/" ;  // 경로지정

    if (options.expires instanceof Date) {
        options.expires = options.expires.toUTCString(); // 생 Date 객체라면 형식에 맞게 인코딩
    }

    let updatedCookie = encodeURIComponent(name) + "=" + encodeURIComponent(value) ;

    for (let optionKey in options) {
        updatedCookie += "; " + optionKey;
        let optionValue = options[optionKey];
        if (optionValue !== true) { // 밸류가 없다면
            updatedCookie += "=" + optionValue;
        }
    }

    document.cookie = updatedCookie; // 새로 갱신
} ;

bidengine.fnDeleteCookie = (name) => { // 해당 쿠키 요소만 삭제
    bidengine.fnSetCookie(name, "", {
      'max-age': -1
    })
} ;

bidengine.fnDeleteAllCookies = () => {
    var cookies = document.cookie.split(";");
    for (var i = 0; i < cookies.length; i++) {
       var cookie = cookies[i] ;
       var eqPos = cookie.indexOf("=");
       var name = eqPos > -1 ? cookie.substr(0, eqPos) : cookie;
       bidengine.fnDeleteCookie( name.trim() ) ;
    }
} ;

bidengine.fnHistoryPushState = ( sEvtCode, jUrlParam, jEvtData = {} ) => {
    let jUrlSelf   = new URL(window.location.href) ;
    let jUrlParams = jUrlSelf.searchParams ;
    for ( const [sKey, sValue] of Object.entries(jUrlParam)) {
        if(!sValue)
            jUrlParams.delete(sKey) ;
        else
            jUrlParams.set(sKey, sValue) ;
    }
    jEvtData.evt_code = sEvtCode ;
    jEvtData.bid_act  = "pushstate" ;
    history.pushState(jEvtData, "", jUrlSelf.toString()) ;
    $("[bid-listener='body']").trigger("bid-event", jEvtData) ;
} ;


/*-- AddOn jQuery PlugIn Function ; 4개 --
1. $.fn.serializeObject : Form Tag의 데이타 확인 Return 하는 값을 console.log() 로 확인이 가능하다.
2. $.fn.serializeFiles  : Form Tag의 데이타 & File 확인 Return 하는 값을 console.log() 로 확인이 불가하다.
3. $.unparam : "bidengine.upparam" 의 확장판
4. $(document).ajaxSuccess : Ajax Success Global Setting
--*/
(function($) {
    $.fn.serializeObject = function() { var obj = null; try { if(this[0].tagName && this[0].tagName.toUpperCase() == "FORM" ) { var arr = this.serializeArray(); if(arr){ obj = {}; jQuery.each(arr, function() { obj[this.name] = this.value; }); } } }catch(e) { alert(e.message); }finally {} return obj; }
    $.fn.serializeFiles  = function() {
        var $Form = $(this),
            oFormData   = new FormData() ,
            aFormParams = $Form.serializeArray() ;

        $.each($Form.find('input[type="file"]'), function(i, tag) {
            $.each($(tag)[0].files, function(i, file) {
                oFormData.append(tag.name, file);
            } ) ;
        } ) ;

        $.each(aFormParams, function(i, jVal) {
            oFormData.append( jVal.name, jVal.value) ;
        });
        return oFormData ;
    } ;
    $.unparam = function(input) {
		var items, temp,
    		// Expresiones regulares
			expBrackets = /\[(.*?)\]/g,
			expVarname = /(.+?)\[/,
    		// Contenedor para almacenar el resultado
			result = {} ;

        // Descartamos entradas que no sean cadenas de texto o se encuentren vacías
		if ((temp = $.type(input)) != 'string' || (temp == 'string' && !temp.length))
			return {} ;

        // Decodificamos la entrada y la dividimos en bloques
		items = decodeURIComponent(input).split('&') ;

		// Es necesario que los datos anteriores no se encuentren vacíos
		if (!(temp = items.length) || (temp == 1 && temp === ''))
			return result;

		// Recorremos los datos
		$.each(items, function(index, item) {
			// Es necesario que no se encuentre vacío
			if (!item.length)
				return;
			// Iniciamos la divisón por el caracter =
			temp = item.split('=');
			// Obtenemos el nombre de la variable
			var key = temp.shift(),
			// Y su valor
				value = temp.join('=').replace(/\+/g, ' '),
				size, link, subitems = [];
			// Es necesario que el nombre de la clave no se encuentre vacío
			if (!key.length)
				return;
			// Comprobamos si el nombre de la clave tiene anidaciones
			while((temp = expBrackets.exec(key)))
				subitems.push(temp[1]);

			// Si no tiene anidaciones
			if (!(size = subitems.length)) {
				// Guardamos el resultado directamente
				result[key] = value;
				// Continuamos con el siguiente dato
				return;
			}
			// Decrementamos el tamaño de las anidaciones para evitar repetidas restas
			size--;
			// Obtenemos el nombre real de la clave con anidaciones
			temp = expVarname.exec(key);
			// Es necesario que se encuentre y que no esté vacío
			if (!temp || !(key = temp[1]) || !key.length)
				return;

			// Al estar todo correcto, comprobamos si el contenedor resultante es un objecto
			if ($.type(result[key]) != 'object')
				// Si no lo es forzamos a que lo sea
				result[key] = {};

			// Creamos un enlace hacia el contenedor para poder reccorrerlo a lo largo de la anidación
			link = result[key];
			// Recorremos los valores de la anidación
			$.each(subitems, function(subindex, subitem) {
				// Si el nombre de la clave se encuentra vacío (varname[])
				if (!(temp = subitem).length) {
					temp = 0;
					// Recorremos el enlace actual
					$.each(link, function(num) {
						// Si el índice es un número entero, positivo y mayor o igual que el anterior
						if (!isNaN(num) && num >= 0 && (num%1 === 0) && num >= temp)
							// Guardamos dicho número y lo incrementamos en uno
							temp = Number(num)+1;
					});
				}
				// Si se llegó al final de la anidación
				if (subindex == size) {
					// Establecemos el valor en el enlace
					link[temp] = value;
				} else if ($.type(link[temp]) != 'object') { // Si la anidación no existe
					// Se crea un objeto con su respectivo enlace
					link = link[temp] = {};
				} else { // Si la anidación existe
					// Cambiamos el enlace sin sobreescribir datos
					link = link[temp];
				}
			});
		});
		// Retornamos el resultado en forma de objeto
		return result ;
	} ;
    $("body").on("bid-event.body",( jEvtSelf, jEvtData ) => {
        let $BodyListener = $("[bid-interact='bodylistener']") ;
        for( let i = 0 ; i < $BodyListener.length ; i ++ ) {
            $($BodyListener[i]).trigger("bid-event", jEvtData) ;
        }
    }) ;
    $(document).ajaxStart( (jEvtAjax) => {
        // console.log("### Global AjaxStart ###") ;
        // console.log(jEvtAjax) ;
    }) ;
    $(document).ajaxStop( (jEvtAjax) => {
