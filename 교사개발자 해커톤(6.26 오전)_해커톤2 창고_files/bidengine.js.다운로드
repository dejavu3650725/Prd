bidengine.uniqid = (prefix, more_entropy) => {
    // +   original by: Kevin van Zonneveld (http://kevin.vanzonneveld.net)
    // +    revised by: Kankrelune (http://www.webfaktory.info/)
    // %        note 1: Uses an internal counter (in php_js global) to avoid collision
    // *     example 1: uniqid();
    // *     returns 1: 'a30285b160c14'
    // *     example 2: uniqid('foo');
    // *     returns 2: 'fooa30285b1cd361'
    // *     example 3: uniqid('bar', true);
    // *     returns 3: 'bara20285b23dfd1.31879087'
    if (typeof prefix === 'undefined') prefix = "";

    var retId;
    var formatSeed = function (seed, reqWidth) {
        seed = parseInt(seed, 10).toString(16); // to hex str
        if (reqWidth < seed.length) { // so long we split
            return seed.slice(seed.length - reqWidth);
        }
        if (reqWidth > seed.length) { // so short we pad
            return Array(1 + (reqWidth - seed.length)).join('0') + seed;
        }
        return seed ;
    };

    // BEGIN REDUNDANT
    if (!this.php_js) {
        this.php_js = {} ;
    }

    // END REDUNDANT
    if (!this.php_js.uniqidSeed) { // init seed with big random int
        this.php_js.uniqidSeed = Math.floor(Math.random() * 0x75bcd15);
    }
    this.php_js.uniqidSeed++;

    retId = prefix; // start with prefix, add current milliseconds hex string
    retId += formatSeed(parseInt(new Date().getTime() / 1000, 10), 8);
    retId += formatSeed(this.php_js.uniqidSeed, 5); // add seed hex string
    if (more_entropy) {
        // for more entropy we add a float lower to 10
        retId += (Math.random() * 10).toFixed(8).toString();
    }
    return retId;
} ;

bidengine.makeid = (iLength, sRndType = "NA" ) => {
    let sText = "" ;
    let aRndType = Array.from(sRndType) ;

    // let sPossible = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789" ;
    let sPossible = "", cChar ;

    for( let i = 0 ; i < aRndType.length ; i ++ ) {
        cChar = aRndType[i] ;
        switch(cChar) {
            case "A"  : sPossible += "ABCDEFGHIJKLMNOPQRSTUVWXYZ" ;          break ;
            case "a"  : sPossible += "abcdefghijklmnopqrstuvwxyz" ;          break ;
            case "N"  : sPossible += "0123456789" ;                          break ;
            case "#"  : sPossible += "!@#$%^&"    ;                          break ;
        }
    }
    for ( let i = 0 ; i < iLength ; i++ )
        sText += sPossible.charAt(Math.floor(Math.random() * sPossible.length)) ;

    return sText ;
} ;

bidengine.parseURL = (sParseUrl = null) => {
    sParseUrl = sParseUrl?sParseUrl:document.location.href ;
    var parser = document.createElement('a') , searchObject = {} , queries, split, i ;
    // Let the browser do the work
    parser.href = sParseUrl ;
    // Convert query string to object
    queries = parser.search.replace(/^\?/, '').split('&');
    for( i = 0; i < queries.length; i++ ) {
        split = queries[i].split('=') ;
        if(!split[0]) continue ;
        searchObject[split[0]] = split[1];
    }
    return {
        protocol: parser.protocol,
        host: parser.host,
        hostname: parser.hostname,
        port: parser.port,
        pathname: parser.pathname,
        search: parser.search,
        searchObject: searchObject,
        hash: parser.hash
    } ;
} ;

bidengine.fgUrlQueryParam = (jConfig, sParseUrl = null) => {
    sParseUrl = sParseUrl?sParseUrl:document.location.href ;
    let jParseUrl   = bidengine.parseURL(sParseUrl) ;
    let jQueryParam = JSON.parse(JSON.stringify(jParseUrl.searchObject)) ;
    if(!jQueryParam.bid_route && jConfig.rewrite_url && jParseUrl.pathname.includes("bid_route/")) {
        jQueryParam.bid_route = jParseUrl.pathname.replace("bid_route/", "") ;
    }
    return jQueryParam?jQueryParam:{} ;
} ;

bidengine.fgAddQueryStringToUrl = (sUrl, jQuery) => {
    const oUrl = new URL(sUrl) ;
    // 기존 URL에 새로운 쿼리 매개변수 추가
    Object.keys(jQuery).forEach( sKey => oUrl.searchParams.append(sKey, jQuery[sKey]));
    // 수정된 URL 반환
    return oUrl.toString() ;
}

bidengine.unparam = (url) => {
    let vars = {}, hash, i, urlParams = url.indexOf('?') > -1 ? url.split('?')[1] : url ;
    try {
        let hashes = urlParams.split('&');
        for(i = 0; i < hashes.length; i++) {
            hash = hashes[i].split('=');
            vars[hash[0]] = decodeURIComponent(hash[1]).replace(/\+/g, ' ');
        }
    }
    catch(eCatch) {
        console.log(eCatch) ;
    }
    return vars ;
} ;

bidengine.padnumber = (iLen, iSource, sPad) => {
    let sPadding  = sPad||'0';
    let sSource   = iSource + "" ;
    return sSource.length >= iLen ? sSource : new Array(iLen - sSource.length + 1).join(sPadding) + sSource ;
} ;

bidengine.getstringtime = ( tsCur, sTag ) => {
    let sStrTime = "" ;
    tsCur = tsCur?tsCur:new Date().getTime() ;
    let dDate = new Date(parseInt(tsCur)) ;
    let sYYYY = bidengine.padnumber( 4, dDate.getFullYear()  , "0" ) ;
    let sYY   = sYYYY.substring(2) ;
    let sMon  = bidengine.padnumber( 2, dDate.getMonth() + 1 , "0" ) ;
    let sDate = bidengine.padnumber( 2, dDate.getDate()  , "0" ) ;
    let sHour = bidengine.padnumber( 2, dDate.getHours() , "0" ) ;
    let sMin  = bidengine.padnumber( 2, dDate.getMinutes() , "0" ) ;
    let sSec  = bidengine.padnumber( 2, dDate.getSeconds() , "0" ) ;
    let sMsec = bidengine.padnumber( 2, dDate.getMilliseconds() , "0" ) ;
    switch(sTag) {
        case "inputdatetime" :
            sStrTime = sYYYY + "-" + sMon + "-" + sDate + "T" + sHour + ":" + sMin ;
        break ;
        case "text.noyear.datetime" :
            sStrTime = sMon + "/" + sDate + " " + sHour + ":" + sMin ;
        break ;
        case "inputdate" :
        	sStrTime = sYYYY + "-" + sMon + "-" + sDate ;
        break ;
        case "datetime.ms" :
            sStrTime = sYYYY + "-" + sMon + "-" + sDate + "T" + sHour + ":" + sMin + ":" + sSec + "." + sMsec ;
        break ;
        default :
            sStrTime = sTag.replace(/Y/g, sYYYY ).replace(/y/g, sYY ).replace(/m/g, sMon ).replace(/d/g, sDate )
                       .replace(/H/g, sHour ).replace(/i/g, sMin).replace(/s/g, sSec ) ;
        break ;
    }
    return sStrTime ;
} ;

bidengine.JSONHighLight = ( $Body, jSource ) => {
    function syntaxHighlight(json) {
        json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function (match) {
            var cls = 'number';
            if (/^"/.test(match)) {
                if (/:$/.test(match)) {
                    cls = 'key';
                } else {
                    cls = 'string';
                }
            } else if (/true|false/.test(match)) {
                cls = 'boolean';
            } else if (/null/.test(match)) {
                cls = 'null';
            }
            return '<span class="' + cls + '">' + match + '</span>' ;
        });
    }

    let sJson = JSON.stringify(jSource, undefined, 4) ;
    $Body.html(syntaxHighlight(sJson)) ;
    $Body.find(".string").css("color","green") ;
    $Body.find(".number").css("color","darkorange") ;
    $Body.find(".boolean").css("color","blue") ;
    $Body.find(".null").css("color","magenta") ;
    $Body.find(".key").css("color","red") ;
}


/* -- bidengine Hash Library : 3 개 --
1. bidengine.getlocationhash ( sKey )  : Hash Key 값을 가지고 온다.
    * Return : String Value
2. bidengine.setlocationhash ( sKey, sValue , bOnlySet ) : Hash Key 값을 설정한다.
    sKey : Hash key
    sValue : Hash Value
    bOnlySet : Setting 만 할 것인지 아니면, 동작할 것인지 판단
3. bidengine.makehashtag ( sKey, sValue ) : Hash Key 값을 String 으로 Return 한다.
    sKey : Hash key
    sValue : Hash Value
    $ Return : Param String
-- */

bidengine.getlocationhash = function( sKey ) {
    let sHash = window.location.hash.substring(1) ;
    let jHash = (sHash=="")?{}:bidengine.unparam(sHash) ;
    return (sKey)?jHash[sKey]:jHash ;
} ;

bidengine.setlocationhash = function( sKey, sValue, bOnlySet = true, bInit = false ) {
    let sHash, jHash ;
    if(bInit) {
        jHash = {} ;
    }
    else {
        sHash = window.location.hash.substring(1) ;
        jHash = (sHash=="")?{}:bidengine.unparam(sHash) ;
    }
    console.log(sValue) ;
    jHash[sKey] = sValue ;
    sHash = $.param(jHash) ;
    window.bidengine.sethashtag = bOnlySet ;
    window.location.hash = sHash ;
} ;

bidengine.setlocationhashjson = ( jSetHash, bOnlySet = true, bInit = false ) => {
    let sHash, jHash ;
    if(bInit) {
        jHash = {} ;
    }
    else {
        sHash = window.location.hash.substring(1) ;
        jHash = (sHash=="")?{}:bidengine.unparam(sHash) ;
    }
    Object.assign(jHash,jSetHash) ;
    sHash = $.param(jHash) ;
    window.bidengine.sethashtag = bOnlySet ;
    window.location.hash = sHash ;
} ;

bidengine.makehashtag = function( sKey, sValue, bInit = false ) {
    let sHash, jHash ;
    if(bInit) {
        jHash = {} ;
    }
    else {
        sHash = window.location.hash.substring(1) ;
        jHash = (sHash=="")?{}:bidengine.unparam(sHash) ;
    }
    jHash[sKey] = sValue ;
    return $.param(jHash) ;
} ;

/*-- 13. 객체주요함수 "urlhash" : URL Hash Tag 와 관련된 함수 --
    13.1. fnGetJsonUrlHash(sHashCode) : Hash Tag 정보에서 jParam 정보로 데이타를 이동한다.
    13.2. fnActJsonUrlHash(sHashCode, jHashPrep) : Hash Tag 정보를 설정한다. HashChange Event 가 발생한다.
--*/
bidengine.fnGetJsonUrlHash = (sHashCode) => {
    let sHashValue = bidengine.getlocationhash(sHashCode) ;
    try {
        if(sHashValue)
            return JSON.parse(sHashValue) ;
        return {} ;
    }
    catch(eCatch) {
        console.log("Error HashCode : " + sHashCode) ;
        return {} ;
    }
} ;

bidengine.fnSetJsonUrlHash = (sHashCode, jHashPrep) => {
    jHashPrep._bid_ts = new Date().getTime() ;
    bidengine.setlocationhash(sHashCode, JSON.stringify(jHashPrep)) ;
} ;

/*---- Bid Certification Library : 6 개 ----
1. bidengine.login ( jBID, jLogin, fnCallback) : 회원로그인
    jBID : BID Configuration
    jLogin : user_id, user_pw, keep = true / false
    fnCallback : Callback Function ( jError, UserInfo)
2. bidengine.logout ( jBID, fnCallback) : 회원로그아웃
    jBID : BID Configuration
    fnCallback : Callback Function ( jError, True / False )
3. bideigne.logstate ( jBID, fnCallback) : 회원현재 상황 확인
    jBID : BID Configuration
    fnCallback : Callback Function ( jError, UserInfo )
4. bidengine.logswitch( jBID, jLogSwitch, fcLogSwitch)
    jLogSwitch : switch_user
-------------------------------------*/
bidengine.login = function( jBID, jLogin, fcLogin) {
